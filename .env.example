# ════════════════════════════════════════════════════════════
#  CRYPTO SIGNAL BOT — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ─── Telegram Reader (get from https://my.telegram.org) ─────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# Comma-separated channel usernames or numeric IDs to monitor
# Example: CryptoSignalsVIP,AnotherChannel,-1001234567890
TELEGRAM_CHANNELS=channel_username1,channel_username2

# How many old messages to scan on first launch (set 0 to skip history)
TELEGRAM_HISTORY_LIMIT=5000

# ─── Binance Futures API ─────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Set to true for testnet (RECOMMENDED while testing)
BINANCE_TESTNET=true

# ─── Bot Notifications (optional) ────────────────────────────
# Create a bot via @BotFather and get the chat ID via @userinfobot
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# Discord webhook URL (optional)
NOTIFY_DISCORD_WEBHOOK=

# ─── Runtime ─────────────────────────────────────────────────
# Set to true to simulate trades without placing real orders
DRY_RUN=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
